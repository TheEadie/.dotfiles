{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git *)",
      "Bash(dotnet *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(gh *)",
      "Bash(~/.claude/scripts/gh-sticky *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl http://*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-firewall.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-sensitive-files.py"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -Is) user=${USER} tool=${CLAUDE_TOOL_NAME}\" >> ~/.claude/audit.log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "redgate-skills": {
      "source": {
        "source": "github",
        "repo": "red-gate/skills-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "npmjs.com",
        "registry.npmjs.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp/build",
        "/run/user/1000/ssh-agent.socket"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh"
      ],
      "allowRead": [
        "~/.ssh/known_hosts"
      ]
    },
    "excludedCommands": [
      "git *"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}
